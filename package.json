{
  "name": "mcp-prompt-optimizer-local",
  "version": "4.0.4",
  "description": "Advanced cross-platform prompt optimization with MCP integration and 120+ optimization rules",
  "main": "index.js",
  "bin": {
    "mcp-optimizer": "index.js"
  },
  "scripts": {
    "test": "node index.js --test",
    "health": "node index.js --health",
    "tools": "node index.js --tools",
    "postinstall": "node secure-postinstall.js",
    "validate": "node verify-implementation.js",
    "optimize": "node index.js --optimize",
    "check-license": "node index.js --health",
    "generate-manifest": "node secure-update/generate-manifest.js",
    "generate-manifest-dev": "node secure-update/generate-manifest.js --dev-mode"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "prompt-optimization",
    "ai",
    "claude",
    "prompt-engineering",
    "cross-platform",
    "local-ai",
    "privacy",
    "optimization-rules",
    "context-detection",
    "llm-enhancement"
  ],
  "author": "Prompt Optimizer Team <support@promptoptimizer.xyz>",
  "license": "Proprietary",
  "engines": {
    "node": ">=16.0.0"
  },
  "os": [
    "win32",
    "darwin",
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "files": [
    "index.js",
    "lib/",
    "bin/",
    "secure-postinstall.js",
    "secure-update/",
    "manifest.json",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "CROSS-PLATFORM.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.1"
  },
  "devDependencies": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcp-prompt-optimizer/local-npm.git"
  },
  "bugs": {
    "url": "https://github.com/mcp-prompt-optimizer/local-npm/issues"
  },
  "homepage": "https://promptoptimizer.xyz",
  "config": {
    "securityRequired": true,
    "crossPlatform": true,
    "platforms": [
      "win32-x64",
      "darwin-x64",
      "darwin-arm64",
      "linux-x64",
      "linux-arm64"
    ],
    "binaryIntegrity": true,
    "freeTierSupport": true
  },
  "platforms": {
    "win32-x64": {
      "binary": "mcp-optimizer-windows-x64.exe",
      "supported": true
    },
    "darwin-x64": {
      "binary": "mcp-optimizer-macos-x64",
      "supported": true
    },
    "darwin-arm64": {
      "binary": "mcp-optimizer-macos-arm64",
      "supported": true
    },
    "linux-x64": {
      "binary": "mcp-optimizer-linux-x64",
      "supported": true
    },
    "linux-arm64": {
      "binary": "mcp-optimizer-linux-arm64",
      "supported": true
    }
  },
  "security": {
    "cross_platform_support": true,
    "binary_integrity": true,
    "api_key_validation": true,
    "quota_enforcement": true
  },
  "mcpTools": {
    "optimize_prompt": {
      "description": "Advanced prompt optimization with 120+ rules",
      "categories": [
        "prompt-engineering",
        "ai-enhancement"
      ]
    },
    "template_management": {
      "description": "Template-based optimization system",
      "categories": [
        "templates",
        "reusability"
      ]
    },
    "quota_status": {
      "description": "Check current usage quota and limits",
      "categories": [
        "monitoring",
        "quota-management"
      ]
    }
  }
}
